{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pao.lwar-registration-response.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "instance_id", "accepted", "decided_at"],
  "properties": {
    "schema_version": {"const": "pao.lwar-registration-response.v1"},
    "request_id": {"type": "string", "pattern": "^lwar-reg-[a-f0-9]{32}$"},
    "instance_id": {"type": "string", "pattern": "^lwar-instance-[a-f0-9]{32}$"},
    "accepted": {"type": "boolean"},
    "lwar_id": {"type": ["string", "null"], "pattern": "^LWAR[1-9][0-9]*$"},
    "generation": {"type": ["integer", "null"], "minimum": 1},
    "registry_version": {"type": ["integer", "null"], "minimum": 1},
    "state": {"enum": ["on", "unregistered"]},
    "behavior_contract": {"const": "lwar-runtime.v2-adp"},
    "reason": {"type": ["string", "null"]},
    "decided_at": {"type": "string", "format": "date-time"}
  }
}
