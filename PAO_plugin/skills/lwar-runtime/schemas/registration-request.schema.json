{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pao.lwar-registration-request.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "instance_id",
    "requested_lwar_id",
    "allocation_mode",
    "requested_state",
    "profile",
    "behavior_contract",
    "created_at"
  ],
  "properties": {
    "schema_version": {"const": "pao.lwar-registration-request.v1"},
    "request_id": {"type": "string", "pattern": "^lwar-reg-[a-f0-9]{32}$"},
    "instance_id": {"type": "string", "pattern": "^lwar-instance-[a-f0-9]{32}$"},
    "requested_lwar_id": {
      "oneOf": [
        {"type": "null"},
        {"type": "string", "pattern": "^LWAR[1-9][0-9]*$"}
      ]
    },
    "allocation_mode": {"enum": ["auto", "explicit"]},
    "requested_state": {"const": "on"},
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_name", "model", "adapter_id", "vendor_family", "interface", "capabilities"],
      "properties": {
        "runtime_name": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "adapter_id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
        "vendor_family": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
        "interface": {"enum": ["cli", "tui", "agent", "build"]},
        "capabilities": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
          "uniqueItems": true
        }
      }
    },
    "behavior_contract": {"const": "lwar-runtime.v2-adp"},
    "runtime_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
