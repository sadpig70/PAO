{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pao.lwar-registry-state.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_version", "allocation_strategy", "slots", "updated_at"],
  "properties": {
    "schema_version": {"const": "pao.lwar-registry-state.v1"},
    "registry_version": {"type": "integer", "minimum": 1},
    "allocation_strategy": {"const": "lowest_available"},
    "slots": {
      "type": "object",
      "patternProperties": {
        "^LWAR[1-9][0-9]*$": {
          "type": "object",
          "additionalProperties": false,
          "required": ["instance_id", "generation", "state", "profile", "registered_at"],
          "properties": {
            "instance_id": {"type": "string", "pattern": "^lwar-instance-[a-f0-9]{32}$"},
            "generation": {"type": "integer", "minimum": 1},
            "state": {"enum": ["on", "draining", "off"]},
            "profile": {"type": "object"},
            "registered_at": {"type": "string", "format": "date-time"},
            "last_seen": {"type": ["string", "null"], "format": "date-time"}
          }
        }
      },
      "additionalProperties": false
    },
    "updated_at": {"type": "string", "format": "date-time"}
  }
}
