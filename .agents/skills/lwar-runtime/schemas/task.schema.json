{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pao.task.v1",
  "type": "object",
  "required": ["schema_version", "task_id", "workflow_id", "lwar_id", "instance_id", "generation", "goal", "instructions", "completion_criteria", "cwd", "timeout_s", "permissions", "created_at"],
  "properties": {
    "schema_version": {"const": "pao.task.v1"},
    "task_id": {"type": "string", "pattern": "^task-[A-Za-z0-9][A-Za-z0-9._-]*$"},
    "workflow_id": {"type": "string"},
    "lwar_id": {"type": "string", "pattern": "^LWAR[1-9][0-9]*$"},
    "instance_id": {"type": "string", "pattern": "^lwar-instance-[a-f0-9]{32}$"},
    "generation": {"type": "integer", "minimum": 1},
    "registry_version": {"type": "integer", "minimum": 1},
    "goal": {"type": "string", "minLength": 1},
    "instructions": {"type": "string", "minLength": 1},
    "completion_criteria": {"type": "array", "items": {"type": "string"}},
    "cwd": {"type": "string", "minLength": 1},
    "timeout_s": {"type": "integer", "minimum": 1},
    "permissions": {"type": "object"},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
