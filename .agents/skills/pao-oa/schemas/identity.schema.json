{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pao.lwar-identity.v1",
  "type": "object",
  "required": ["schema_version", "lwar_id", "instance_id", "generation", "registry_version", "state", "behavior_contract", "profile", "adopted_at"],
  "properties": {
    "schema_version": {"const": "pao.lwar-identity.v1"},
    "lwar_id": {"type": "string"},
    "instance_id": {"type": "string"},
    "generation": {"type": "integer", "minimum": 1},
    "registry_version": {"type": "integer", "minimum": 1},
    "state": {"enum": ["on", "draining", "off"]},
    "behavior_contract": {"const": "lwar-runtime.v2-adp"},
    "profile": {"type": "object"},
    "bus_root": {"type": "string", "minLength": 1},
    "adopted_at": {"type": "string", "format": "date-time"}
  }
}
