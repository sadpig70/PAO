{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pao.lwar-lifecycle-response.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "lwar_id",
    "instance_id",
    "generation",
    "accepted",
    "previous_state",
    "resulting_state",
    "registry_version",
    "reason",
    "decided_at"
  ],
  "properties": {
    "schema_version": {"const": "pao.lwar-lifecycle-response.v1"},
    "request_id": {"type": "string", "pattern": "^lwar-state-[a-f0-9]{32}$"},
    "lwar_id": {"type": "string", "pattern": "^LWAR[1-9][0-9]*$"},
    "instance_id": {"type": "string", "pattern": "^lwar-instance-[a-f0-9]{32}$"},
    "generation": {"type": "integer", "minimum": 1},
    "accepted": {"type": "boolean"},
    "previous_state": {"enum": ["on", "draining", "off"]},
    "resulting_state": {"enum": ["on", "draining", "off", "deregistered"]},
    "registry_version": {"type": ["integer", "null"], "minimum": 1},
    "reason": {"type": ["string", "null"]},
    "decided_at": {"type": "string", "format": "date-time"}
  }
}
