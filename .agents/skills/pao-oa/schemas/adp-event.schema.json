{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pao.adp-event.v1",
  "type": "object",
  "required": ["event"],
  "properties": {
    "event": {"enum": ["task_received", "idle_timeout", "state_wait", "control", "adp_error"]},
    "lwar_id": {"type": "string", "pattern": "^LWAR[1-9][0-9]*$"},
    "task_id": {"type": "string"},
    "task": {"type": "object"},
    "command": {"type": ["string", "null"]},
    "action": {"type": "string"},
    "error": {"type": "string"}
  }
}
