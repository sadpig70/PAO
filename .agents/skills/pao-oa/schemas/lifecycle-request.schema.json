{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pao.lwar-lifecycle-request.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "lwar_id",
    "instance_id",
    "generation",
    "registry_version",
    "requested_state",
    "created_at"
  ],
  "properties": {
    "schema_version": {"const": "pao.lwar-lifecycle-request.v1"},
    "request_id": {"type": "string", "pattern": "^lwar-state-[a-f0-9]{32}$"},
    "lwar_id": {"type": "string", "pattern": "^LWAR[1-9][0-9]*$"},
    "instance_id": {"type": "string", "pattern": "^lwar-instance-[a-f0-9]{32}$"},
    "generation": {"type": "integer", "minimum": 1},
    "registry_version": {"type": "integer", "minimum": 1},
    "requested_state": {"enum": ["on", "draining", "off", "deregistered"]},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
