{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pao.control.v1",
  "type": "object",
  "required": ["schema_version", "control_id", "lwar_id", "instance_id", "generation", "command", "created_at"],
  "properties": {
    "schema_version": {"const": "pao.control.v1"},
    "control_id": {"type": "string", "pattern": "^control-[a-f0-9]{32}$"},
    "lwar_id": {"type": "string", "pattern": "^LWAR[1-9][0-9]*$"},
    "instance_id": {"type": "string", "pattern": "^lwar-instance-[a-f0-9]{32}$"},
    "generation": {"type": "integer", "minimum": 1},
    "command": {"enum": ["shutdown", "ping", "cancel", "drain"]},
    "task_id": {"type": ["string", "null"]},
    "reason": {"type": ["string", "null"]},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
