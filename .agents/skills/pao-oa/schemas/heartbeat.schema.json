{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pao.heartbeat.v1",
  "type": "object",
  "required": ["schema_version", "lwar_id", "instance_id", "generation", "status", "current_task_id", "last_seen"],
  "properties": {
    "schema_version": {"const": "pao.heartbeat.v1"},
    "lwar_id": {"type": "string", "pattern": "^LWAR[1-9][0-9]*$"},
    "instance_id": {"type": "string"},
    "generation": {"type": "integer", "minimum": 1},
    "status": {"enum": ["starting", "watching", "running", "idle", "on", "draining", "off", "control"]},
    "current_task_id": {"type": ["string", "null"]},
    "last_seen": {"type": "string", "format": "date-time"}
  }
}
