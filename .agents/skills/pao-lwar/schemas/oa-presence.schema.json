{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pao.oa-presence.v1",
  "type": "object",
  "required": ["schema_version", "oa_id", "status", "last_seen", "expires_at"],
  "properties": {
    "schema_version": {"const": "pao.oa-presence.v1"},
    "oa_id": {"type": "string", "minLength": 1},
    "status": {"const": "supervising"},
    "last_seen": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
