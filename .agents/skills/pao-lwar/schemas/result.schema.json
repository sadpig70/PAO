{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pao.result.v1",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "lwar_id",
    "instance_id",
    "generation",
    "status",
    "summary",
    "evidence",
    "artifacts",
    "exit_code",
    "submitted_at"
  ],
  "properties": {
    "schema_version": {
      "const": "pao.result.v1"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task-[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "workflow_id": {
      "type": ["string", "null"],
      "pattern": "^workflow-[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "lwar_id": {
      "type": "string",
      "pattern": "^LWAR[1-9][0-9]*$"
    },
    "instance_id": {
      "type": "string",
      "pattern": "^lwar-instance-[a-f0-9]{32}$"
    },
    "generation": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "enum": [
        "succeeded",
        "failed",
        "blocked",
        "cancelled",
        "interrupted",
        "timed_out",
        "protocol_error"
      ]
    },
    "summary": {
      "type": "string"
    },
    "evidence": {
      "type": "object"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "description": "legacy pre-0.6 artifact path"
          },
          {
            "type": "object",
            "required": [
              "path",
              "sha256",
              "size_bytes",
              "snapshot"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "size_bytes": {
                "type": "integer",
                "minimum": 0
              },
              "snapshot": {
                "type": "string",
                "description": "root-relative content-addressed copy under var/artifacts/"
              }
            }
          }
        ]
      }
    },
    "exit_code": {
      "type": "integer"
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "claim_token": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^claim-[a-f0-9]{32}$"
        }
      ]
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "artifact_warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
